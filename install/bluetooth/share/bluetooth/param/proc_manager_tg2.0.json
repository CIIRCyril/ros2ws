{
  "config": {
    "audio_player": "192.168.41.2",
    "audio_path": "/home/nvidia/data/speech",
    "audio_list": [ "0.mp3", "1.mp3", "2.mp3", "3.mp3", "4.mp3" ]
  },
  "topic":[
    {
      "name": "/bodycontrol_state",
      "msgtype": "bodyctrl_msgs::NodeState"
    },{
      "name": "/power/board/key_status",
      "msgtype": "bodyctrl_msgs::PowerBoardKeyStatus"
    },{
      "name": "/power/board/status",
      "msgtype": "bodyctrl_msgs::PowerStatus"
    },{
      "name": "/sbus_data",
      "msgtype": "sensor_msgs::Joy"
    }
  ],
  "proc": [
    {
      "name": "power_board",
      "enable": true,
      "shell": "roslaunch power_board power_board.launch",
      "boot_start": true,
      "ready_topic": "power_board_state"
    },{
      "name": "usb_sbus",
      "enable": true,
      "shell": "roslaunch usb_sbus sbus.launch",
      "shell1": "rosrun usb_sbus usb_sbus_node",
      "boot_start": true
    },{
      "name": "body_control",
      "enable": true,
      "shell": "roslaunch body_control body_no_sbus.launch",
      "shell_max2": "roslaunch body_control motion_evt_max2.launch",
      "boot_start": false,
      "ready_topic": "bodycontrol_state",
      "ready_timeout": 20
    },{
      "name": "motion",
      "enable": true,
      "shell": "roslaunch motion_control motion.launch"
    }
  ],
  "trigger": [
    {
      "type": "OnInitStart",
      "enable": true,
      "action": [
        { "audio_file": "kaijiqidong.mp3" }
      ]
    },
    {
      "type": "OnInitFinish",
      "enable": true,
      "action": [
        { "power_light": "PowerOnFinish" },
        { "power_light": "ServiceStart" }
      ]
    },
    {
      "type": "OnNodeState",
      "enable": true,
      "topic": "power_board_state",
      "value": [ "0", "1" ],
      "action": [
        { "power_light": "PowerOnFinish" }
      ]
    },
    {
      "type": "OnNodeState",
      "enable": true,
      "topic": "bodycontrol_state",
      "value": [ "0", "1" ],
      "sleep_time_ms": 30000,
      "condition": [
        { "robot_status": "!=48vOff" }
      ],
      "stop_proc": [ "motion" ],
      "start_proc": [ "motion" ],
      "action": [
        { "robot_status": "Running" }
      ]
    },
    {
      "type": "OnRobotStatusChanged",
      "enable": true,
      "value": [ "", "48vOff" ],
      "value1": [ "Running", "48vOff" ],
      "stop_proc": [ "motion", "body_control" ],
      "action": [
        { "audio_file": "guzhang.mp3" },
        { "power_light": "DeviceFaultOccur" }
      ]
    },
    {
      "type": "OnRobotStatusChanged",
      "enable": true,
      "value": [ "", "Running" ],
      "action": [
        { "power_light1": "ServiceFinish" },
        { "power_light": "SelfCheckSuccess" },
        { "audio_file": "chenggong.wav" }
      ]
    },
    {
      "type": "OnRobotStatusChanged",
      "enable": true,
      "value": [ "", "Initing" ],
      "count": -1,
      "action": [
        { "audio_file": "zijianguocheng.mp3" }
      ]
    },
    {
      "type": "OnJoyButtonPressed",
      "enable": true,
      "button": "A",
      "value": [ "", "1" ],
      "condition": [
        { "robot_status": "!=Running" },
        { "robot_status": "!=48vOff" }
      ],
      "start_proc": [ "body_control" ],
      "action": [
        { "power_light": "ServiceFinish" },
        { "power_light": "SelfCheckStart" },
        { "audio_file": "anjianyin.mp3" },
        { "robot_status": "Initing" }
      ],
      "failed": [
        { "audio_file": "guzhang.mp3" }
      ]
    },
    {
      "type": "OnJoyButtonPressed",
      "enable": true,
      "button": "G",
      "value": [ "", "-1" ],
      "action": [
        { "play_audio_index": "-1" }
      ]
    },
    {
      "type": "OnJoyButtonPressed",
      "enable": true,
      "button": "G",
      "value": [ "", "0" ],
      "action": [
        { "stop_play_audio": "true" }
      ]
    },
    {
      "type": "OnJoyButtonPressed",
      "enable": true,
      "button": "F",
      "value": [ "", "-1" ],
      "action": [
        { "change_audio_index": "next" }
      ]
    },
    {
      "type": "OnJoyButtonPressed",
      "enable": true,
      "button": "F",
      "value": [ "", "1" ],
      "action": [
        { "change_audio_index": "previous" }
      ]
    },
    {
      "type": "OnBatteryCharging",
      "enable": true,
      "action": [
        { "audio_file": "kaishichongdian.mp3" }
      ]
    }
  ]
}
